#!/usr/bin/env bash
#
# netscan — the friendly front-end for netscan-go. `netscan scan` runs the whole
# pipeline (discovery → enrichment) as one comprehensive command; each raw binary
# stays available as a subcommand for scripting.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SELF")" && pwd)"
BIN="$ROOT/bin"
DEFAULT_DB="scan.db"

die() { echo "netscan: $*" >&2; exit 1; }
note() { echo "netscan: $*" >&2; }
need() { [[ -x "$BIN/$1" ]] || die "$1 not built — run 'make build'"; }

usage() {
	cat >&2 <<'EOF'
netscan — internet-scale port scanner (netscan-go)

USAGE
  netscan scan --targets CIDR[,CIDR|@file] [options]
  netscan status [--db FILE] [--host IP] [--interval DUR]
  netscan discover|ingest|enrich [flags...]   # raw binaries (advanced/scripting)
  netscan iptables-clean                      # remove leftover SYN RST guards

By default `scan` does everything reasonable, no config: it discovers hosts (SYN
if available, else connect) on the top-100 common ports, then fully enriches them
(protocol detection, HTTP + TLS on web, banner on non-web, reverse DNS).

SCAN OPTIONS
  Targets:
    --targets CIDR[,CIDR|@file]   what to scan (required)
    --exclude / --exclude-file    ranges to skip
    --no-skip-reserved            include reserved/private ranges
  Discovery:
    --ports LIST | --top-ports N  ports to probe (default: top 100); LIST is
                                  80,443,8000-8100 or 'all' (mutually excl.)
    --syn / --connect             force the method (default: auto — SYN if the
                                  binary has CAP_NET_RAW, else connect)
    --rate N                      max probes/sec (default 1000; 0 = unlimited)
    --timeout DUR                 per-probe timeout (discovery)
    --workers N                   discovery concurrency
    --resume                      resume the last interrupted scan (same --db)
    --yes                         confirm large scans / --rate 0
  Enrichment:
    --all-ports [SPEC]            ALSO deep-sweep each host's ports (opt-in, heavy):
                                  bare = common set, 'all' = 1-65535, or a spec
    --all-ports-timeout DUR       per-port sweep timeout (default 2s)
    --all-ports-conc N            global cap on simultaneous sweep connects,
                                  across all hosts (default 500; the deep scan's
                                  rate limiter — lower it if your link gets flaky)
    --pipeline FILE               fully custom enrichment graph (advanced)
    --enrich-workers N            enrichment concurrency (default 50)
    --enrich-timeout DUR          per-probe enrichment timeout (default 10s)
  Output:
    --db FILE                     SQLite database (default scan.db)
    --geoip FILE / --asn FILE     GeoIP DBs (auto-detected from data/ if present)

EXAMPLES
  netscan scan --targets 1.1.1.0/24                     # comprehensive default
  netscan scan --targets 1.1.1.0/24 --all-ports         # + deep port sweep (common)
  netscan scan --targets 10.0.0.0/16 --all-ports all --yes
  netscan scan --targets 1.1.1.0/24 --top-ports 1000
  netscan status --db scan.db --host 1.1.1.1
EOF
	exit "${1:-1}"
}

# has_cap: does ns-discover carry the SYN capability?
has_cap() { getcap "$BIN/ns-discover" 2>/dev/null | grep -q cap_net_raw; }
# is_root: are we running as root (can raw-socket without setcap)?
is_root() { [[ "$(id -u)" -eq 0 ]]; }
# passwordless_sudo: can we run sudo without a prompt (for the iptables guard)?
passwordless_sudo() { sudo -n true 2>/dev/null; }

# run_sweep <label> [ns-discover args...] — one discovery sweep to stdout (NDJSON),
# in the resolved TCP method (SYN, with the iptables RST guard when available, or
# connect). Reads $disc_mode / $use_guard / $db from the calling cmd_scan (bash
# dynamic scope).
run_sweep() {
	local label="$1"; shift
	if [[ "$disc_mode" == "syn" ]]; then
		if [[ $use_guard -eq 1 ]]; then
			"$ROOT/scripts/syn-scan.sh" --label "$label" --db "$db" "$@"
		else
			"$BIN/ns-discover" --mode syn --label "$label" --db "$db" "$@"
		fi
	else
		"$BIN/ns-discover" --label "$label" --db "$db" "$@"
	fi
}

cmd_scan() {
	local db="$DEFAULT_DB"
	local method="auto"                 # auto | syn | connect
	local syn_set=0 connect_set=0
	local ports_set=0 topports_set=0
	local all_ports="" all_ports_set=0
	local pipeline_file=""
	local fast=0 widen_ports="1000" widen_min_hosts="1"
	# Discovery args are split so the adaptive pass 2 can reuse the tuning/excludes
	# but swap the targets and port set: tgt (address space), excl (exclusions),
	# tune (rate/timeout/workers/…), p1ports (pass-1 ports).
	local tgt=() excl=() tune=() p1ports=() geo=() geo_set=0 enrich=()

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h|--help) usage 0 ;;
			--db) db="$2"; shift 2 ;;
			--db=*) db="${1#*=}"; shift ;;
			# method
			--syn) method="syn"; syn_set=1; shift ;;
			--connect) method="connect"; connect_set=1; shift ;;
			# adaptive discovery
			--fast|--no-adaptive) fast=1; shift ;;
			--widen-ports) widen_ports="$2"; shift 2 ;;
			--widen-ports=*) widen_ports="${1#*=}"; shift ;;
			--widen-min-hosts) widen_min_hosts="$2"; shift 2 ;;
			--widen-min-hosts=*) widen_min_hosts="${1#*=}"; shift ;;
			# discovery ports (pass 1)
			--ports) ports_set=1; p1ports+=(--ports "$2"); shift 2 ;;
			--ports=*) ports_set=1; p1ports+=("$1"); shift ;;
			--top-ports) topports_set=1; p1ports+=(--top-ports "$2"); shift 2 ;;
			--top-ports=*) topports_set=1; p1ports+=("$1"); shift ;;
			# discovery targets / exclusions
			--targets) tgt+=("$2"); shift 2 ;;
			--targets=*) tgt+=("${1#*=}"); shift ;;
			--exclude|--exclude-file) excl+=("$1" "$2"); shift 2 ;;
			--exclude=*|--exclude-file=*) excl+=("$1"); shift ;;
			# discovery tuning (shared by both passes)
			--rate|--timeout|--workers|--seed) tune+=("$1" "$2"); shift 2 ;;
			--rate=*|--timeout=*|--workers=*|--seed=*) tune+=("$1"); shift ;;
			--no-skip-reserved|--resume|--progress|--yes) tune+=("$1"); shift ;;
			# enrichment (forwarded to ns-enrich)
			--all-ports) all_ports_set=1; all_ports="common"
				if [[ "${2-}" != "" && "${2-}" != --* ]]; then all_ports="$2"; shift; fi; shift ;;
			--all-ports=*) all_ports_set=1; all_ports="${1#*=}"; shift ;;
			--all-ports-timeout) enrich+=(--all-ports-timeout "$2"); shift 2 ;;
			--all-ports-timeout=*) enrich+=("--all-ports-timeout=${1#*=}"); shift ;;
			--all-ports-conc) enrich+=(--all-ports-conc "$2"); shift 2 ;;
			--all-ports-conc=*) enrich+=("--all-ports-conc=${1#*=}"); shift ;;
			--pipeline) pipeline_file="$2"; shift 2 ;;
			--pipeline=*) pipeline_file="${1#*=}"; shift ;;
			--enrich-workers) enrich+=(--workers "$2"); shift 2 ;;
			--enrich-workers=*) enrich+=("--workers=${1#*=}"); shift ;;
			--enrich-timeout) enrich+=(--timeout "$2"); shift 2 ;;
			--enrich-timeout=*) enrich+=("--timeout=${1#*=}"); shift ;;
			# output
			--geoip|--asn) geo+=("$1" "$2"); geo_set=1; shift 2 ;;
			--geoip=*|--asn=*) geo+=("$1"); geo_set=1; shift ;;
			-*) die "unknown scan flag '$1' (see 'netscan scan --help')" ;;
			*) tgt+=("$1"); shift ;;   # bare targets
		esac
	done

	# --- validation: errors on true conflicts, warnings on no-ops ---
	[[ $syn_set -eq 1 && $connect_set -eq 1 ]] && die "--syn and --connect are mutually exclusive"
	[[ $ports_set -eq 1 && $topports_set -eq 1 ]] && die "--ports and --top-ports are mutually exclusive"
	[[ $all_ports_set -eq 1 && -n "$pipeline_file" ]] && die "--all-ports and --pipeline are mutually exclusive"
	if [[ $all_ports_set -eq 0 && ${#enrich[@]} -gt 0 ]] && printf '%s\n' "${enrich[@]}" | grep -qE -- '--all-ports-(timeout|conc)'; then
		note "warning: --all-ports-timeout/--all-ports-conc have no effect without --all-ports"
	fi

	need ns-discover; need ns-ingest; need ns-enrich; need ns-status

	# --- method resolution (root/sudo OR setcap → SYN; else connect) ---
	local use_syn=0 use_guard=0 can_syn=0
	{ is_root || has_cap; } && can_syn=1
	case "$method" in
		syn)     [[ $can_syn -eq 1 ]] || die "SYN needs root/sudo or CAP_NET_RAW ('make setcap') — or use --connect"; use_syn=1 ;;
		connect) use_syn=0 ;;
		auto)    if [[ $can_syn -eq 1 ]]; then use_syn=1; else note "SYN unavailable (run with sudo or 'make setcap') — using connect"; fi ;;
	esac
	local disc_mode="connect"
	if [[ $use_syn -eq 1 ]]; then
		disc_mode="syn"
		if passwordless_sudo; then use_guard=1
		else note "no passwordless sudo → SYN without the iptables RST guard (works, slightly less polite)"; fi
	fi

	# --- privilege drop: under sudo, keep enrichment unprivileged (it parses
	#     untrusted remote data); only ns-discover needs root for raw sockets ---
	local pre=()
	if is_root && [[ -n "${SUDO_USER:-}" ]]; then
		pre=(sudo -u "$SUDO_USER")
		note "enrichment runs as $SUDO_USER (privilege separation); discovery as root"
	elif is_root; then
		note "running fully as root (no \$SUDO_USER to drop enrichment to)"
	fi

	# --- geo: auto-detect data/ unless overridden ---
	if [[ $geo_set -eq 0 ]]; then
		[[ -f "$ROOT/data/dbip-country.mmdb" ]] && geo+=(--geoip "$ROOT/data/dbip-country.mmdb")
		[[ -f "$ROOT/data/dbip-asn.mmdb" ]] && geo+=(--asn "$ROOT/data/dbip-asn.mmdb")
	fi
	[[ $all_ports_set -eq 1 ]] && enrich+=(--all-ports "$all_ports")
	[[ -n "$pipeline_file" ]] && enrich+=(--pipeline "$pipeline_file")

	# --- run: enrichment follows discovery live ---
	"${pre[@]}" "$BIN/ns-enrich" --db "$db" --follow "${enrich[@]}" &
	local epid=$!
	note "live dashboard (other terminal) ->  netscan status --db $db --interval 2s"

	local rc=0
	if [[ $fast -eq 1 ]]; then
		# Single broad pass (no widening, no ICMP).
		run_sweep "" "${tgt[@]/#/--targets=}" "${excl[@]}" "${tune[@]}" "${p1ports[@]}" \
			| "${pre[@]}" "$BIN/ns-ingest" --db "$db" "${geo[@]}" || rc=$?
	else
		# PASS 1 — broad TCP sweep + (if SYN capable) an ICMP liveness sweep; the
		# intermediate ingest keeps the --follow enricher alive for pass 2.
		{
			run_sweep broad "${tgt[@]/#/--targets=}" "${excl[@]}" "${tune[@]}" "${p1ports[@]}"
			[[ $use_syn -eq 1 ]] && "$BIN/ns-discover" --mode icmp --label ping --db "$db" \
				"${tgt[@]/#/--targets=}" "${excl[@]}" "${tune[@]}"
		} | "${pre[@]}" "$BIN/ns-ingest" --db "$db" --intermediate "${geo[@]}" || rc=$?

		# Derive live /24 blocks and widen ports on them (or finalize if none).
		local blocks; blocks="$(mktemp)"
		"$BIN/ns-status" --db "$db" --live-blocks 24 --min-hosts "$widen_min_hosts" >"$blocks" 2>/dev/null || true
		local n; n="$(grep -c . "$blocks" 2>/dev/null || echo 0)"
		local widen_args=(--ports "$widen_ports")
		[[ "$widen_ports" =~ ^[0-9]+$ ]] && widen_args=(--top-ports "$widen_ports")
		if [[ "$n" -gt 0 ]]; then
			note "adaptive: widening $n live /24 block(s)"
			run_sweep "widening $n blocks" --targets "@$blocks" "${excl[@]}" "${tune[@]}" "${widen_args[@]}" \
				| "${pre[@]}" "$BIN/ns-ingest" --db "$db" "${geo[@]}" || rc=$?
		else
			note "adaptive: no live blocks to widen"
			: | "${pre[@]}" "$BIN/ns-ingest" --db "$db" "${geo[@]}" || rc=$?  # finalize (marks ingest done)
		fi
		rm -f "$blocks"
	fi

	[[ $rc -ne 0 ]] && kill "$epid" 2>/dev/null || true
	wait "$epid" 2>/dev/null || true

	# Final summary: a one-shot ns-status renders the completion banner + findings.
	echo >&2
	"$BIN/ns-status" --db "$db" >&2 || true
	return $rc
}

# cmd_iptables_clean removes any leftover RST guards tagged by syn-scan.sh.
cmd_iptables_clean() {
	local n=0 spec
	while IFS= read -r spec; do
		[[ -n "$spec" ]] || continue
		# shellcheck disable=SC2086
		if sudo iptables -D ${spec#-A } 2>/dev/null; then n=$((n + 1)); fi
	done < <(sudo iptables -S OUTPUT 2>/dev/null | grep -F -- netscan-rst-guard)
	note "removed $n leftover netscan RST guard(s)"
}

main() {
	[[ $# -ge 1 ]] || usage
	local cmd="$1"; shift
	case "$cmd" in
		scan)           cmd_scan "$@" ;;
		status)         need ns-status;   exec "$BIN/ns-status" "$@" ;;
		discover)       need ns-discover; exec "$BIN/ns-discover" "$@" ;;
		ingest)         need ns-ingest;   exec "$BIN/ns-ingest" "$@" ;;
		enrich)         need ns-enrich;   exec "$BIN/ns-enrich" "$@" ;;
		iptables-clean) cmd_iptables_clean ;;
		-h|--help|help) usage 0 ;;
		*)              die "unknown command '$cmd' (see 'netscan --help')" ;;
	esac
}

main "$@"
