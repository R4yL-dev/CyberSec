#!/usr/bin/env bash
#
# netscan — front-end for the netscan-go pipeline. Wraps the four binaries so a
# full scan (discover -> ingest -> light enrichment) is a single command, and
# exposes each binary as a subcommand for advanced use.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SELF")" && pwd)"
BIN="$ROOT/bin"
DEFAULT_DB="scan.db"

die() { echo "netscan: $*" >&2; exit 1; }
need() { [[ -x "$BIN/$1" ]] || die "$1 not built — run 'make build'"; }

usage() {
	cat >&2 <<'EOF'
netscan — internet-scale port scanner (netscan-go)

usage:
  netscan scan   --targets CIDR[,CIDR|@file] [--ports P] [--db FILE] [--syn] [--geoip F --asn F] [ns-discover flags...]
  netscan status [--db FILE] [--host IP] [--interval DUR]
  netscan discover|ingest|enrich [flags...]     # pass through to the raw binary
  netscan iptables-clean                        # remove leftover SYN RST guards

examples:
  netscan scan --targets 1.1.1.0/24 --db scan.db
  netscan scan --targets 1.1.1.0/24 --ports 80,443,8080 --syn
  netscan status --db scan.db
  netscan status --db scan.db --host 1.1.1.1

notes:
  'scan' runs a one-shot pipeline: discovery -> ingest -> light enrichment (--drain).
  --syn uses stateless SYN discovery (needs 'make setcap') with a scoped, auto-removed
  iptables RST guard; override its source port with SRC_PORT=NNN.
EOF
	exit 1
}

cmd_scan() {
	local db="$DEFAULT_DB" syn=0 args=() geo_flags=() geo_set=0
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--db)   db="$2"; shift 2 ;;
			--db=*) db="${1#*=}"; shift ;;
			--syn)  syn=1; shift ;;
			--geoip|--asn) geo_flags+=("$1" "$2"); geo_set=1; shift 2 ;;
			--geoip=*|--asn=*) geo_flags+=("$1"); geo_set=1; shift ;;
			-h|--help) usage ;;
			*)      args+=("$1"); shift ;;
		esac
	done
	[[ ${#args[@]} -gt 0 ]] || die "scan needs at least --targets (see 'netscan --help')"
	need ns-discover
	need ns-ingest
	need ns-enrich

	# Geo is default-on when the DBs exist under the repo's data/ (make geoip).
	# Resolve against $ROOT so it works even when netscan is on PATH.
	if [[ $geo_set -eq 0 ]]; then
		[[ -f "$ROOT/data/dbip-country.mmdb" ]] && geo_flags+=(--geoip "$ROOT/data/dbip-country.mmdb")
		[[ -f "$ROOT/data/dbip-asn.mmdb" ]] && geo_flags+=(--asn "$ROOT/data/dbip-asn.mmdb")
	fi

	# Enrichment runs concurrently with discovery: it drains the queue live and
	# exits on its own once ingestion signals completion (store meta flag).
	"$BIN/ns-enrich" --db "$db" --follow &
	local epid=$!

	echo "netscan: live view -> netscan status --db $db --interval 2s" >&2

	local rc=0
	if [[ "$syn" == 1 ]]; then
		# syn-scan.sh does the cap check + scoped iptables guard, and streams NDJSON.
		"$ROOT/scripts/syn-scan.sh" --db "$db" "${args[@]}" | "$BIN/ns-ingest" --db "$db" "${geo_flags[@]}" || rc=$?
	else
		"$BIN/ns-discover" --db "$db" "${args[@]}" | "$BIN/ns-ingest" --db "$db" "${geo_flags[@]}" || rc=$?
	fi

	# On success ingest marked "done" so the follower exits itself; on failure it
	# would poll forever, so stop it. Either way, reap it.
	[[ $rc -ne 0 ]] && kill "$epid" 2>/dev/null || true
	wait "$epid" 2>/dev/null || true
	echo "netscan: done -> $db  (view: netscan status --db $db)" >&2
	return $rc
}

# cmd_iptables_clean removes any leftover RST guards tagged by syn-scan.sh
# (e.g. from a SYN scan that was hard-killed before it could clean up).
cmd_iptables_clean() {
	local n=0 spec
	while IFS= read -r spec; do
		[[ -n "$spec" ]] || continue
		# spec: "-A OUTPUT -p tcp ... --comment netscan-rst-guard -j DROP"
		# shellcheck disable=SC2086
		if sudo iptables -D ${spec#-A } 2>/dev/null; then
			n=$((n + 1))
		fi
	done < <(sudo iptables -S OUTPUT 2>/dev/null | grep -F -- netscan-rst-guard)
	echo "netscan: removed $n leftover netscan RST guard(s)" >&2
}

main() {
	[[ $# -ge 1 ]] || usage
	local cmd="$1"; shift
	case "$cmd" in
		scan)           cmd_scan "$@" ;;
		status)         need ns-status;   exec "$BIN/ns-status" "$@" ;;
		discover)       need ns-discover; exec "$BIN/ns-discover" "$@" ;;
		ingest)         need ns-ingest;   exec "$BIN/ns-ingest" "$@" ;;
		enrich)         need ns-enrich;   exec "$BIN/ns-enrich" "$@" ;;
		iptables-clean) cmd_iptables_clean ;;
		-h|--help|help) usage ;;
		*)              die "unknown command '$cmd' (see 'netscan --help')" ;;
	esac
}

main "$@"
